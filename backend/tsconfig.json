{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "esnext",
    "types": ["node"],
    "outDir": "./dist",
    "sourceMap": true,
    "declaration": true,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "dist"]
}